# Bharat OS ‚Äî environment variable reference (Phase 4.6).
#
# Copy to `.env` and edit. Bharat OS does not source `.env`
# automatically; either pass these to `docker compose` or set them
# in your hosting platform (Render, Railway, Fly.io, k8s).

# ‚îÄ‚îÄ‚îÄ Phase 4.1 ‚Äî security headers + observability ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

# Enable HSTS (`Strict-Transport-Security`). ON in production
# (terminate TLS at the reverse proxy first); OFF in local dev
# (else the browser will refuse plain http://localhost forever).
BHARAT_OS_HSTS=1

# Trust the X-Forwarded-For header for client-IP detection in the
# rate-limiter. Set this ONLY behind a reverse proxy you control ‚Äî
# trusting it on a publicly-bound server lets clients spoof their
# IP and evade rate-limiting.
BHARAT_OS_TRUST_PROXY=1

# CORS allowlist. Comma-separated origins permitted to call the
# API from a different origin. Empty = same-origin only.
# Example: BHARAT_OS_CORS_ORIGINS=https://app.bharat-os.in,https://admin.bharat-os.in
BHARAT_OS_CORS_ORIGINS=

# Structured-log verbosity. debug | info | warn | error.
BHARAT_OS_LOG_LEVEL=info

# ‚îÄ‚îÄ‚îÄ Phase 4.2 ‚Äî store backend ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

# `file` (default) or `sqlite`. Production is sqlite for ACID
# transactions + indexed queries.
BHARAT_OS_STORE_KIND=sqlite

# ‚îÄ‚îÄ‚îÄ Phase 4.3 ‚Äî SMS provider ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

# `log` (default, prints OTPs to logs in dev) or `gupshup` / `msg91`
# / `karix` / `twilio` (require additional env vars below).
BHARAT_OS_SMS_PROVIDER=log

# Phase 5.3 ‚Äî fallback chain. When set (comma-separated provider
# names), overrides BHARAT_OS_SMS_PROVIDER and wraps the listed
# providers in order. The first provider that returns success
# wins; on SMS_PROVIDER_NOT_CONFIGURED or SMS_PROVIDER_REJECTED
# the chain falls through to the next. All providers in the chain
# must still have their credentials configured below (or the
# chain will skip them as not-configured).
#
# Recommended production chains:
#   India primary:        gupshup,msg91   (DLT-compliant onshore)
#   India + intl backup:  gupshup,msg91,twilio
#   Cost-optimised:       msg91,gupshup   (msg91 first for ‚Çπ0.12/SMS)
#
# Per-provider success rates are visible at /metrics under
# bos_sms_send_total{provider,outcome} so ops can tune the order
# based on real-world delivery data.
# BHARAT_OS_SMS_FALLBACK_CHAIN=gupshup,msg91,twilio

# Phase 5.4 ‚Äî per-call timeout + circuit breaker tunables. Defaults
# are chosen for typical India-SMS API latencies (responses in
# <500ms; >3s ‚âà outage). Override only if a specific vendor needs
# different headroom.
#
# ‚Ä¢ BHARAT_OS_SMS_TIMEOUT_MS ‚Äî per-call fetch timeout (default 3000).
#   Vendor takes longer than this ‚Üí aborted as SMS_PROVIDER_REJECTED.
# ‚Ä¢ BHARAT_OS_SMS_CIRCUIT_THRESHOLD ‚Äî consecutive REJECTED failures
#   before the breaker opens (default 5). NOT_CONFIGURED does NOT
#   count (config issues don't auto-heal).
# ‚Ä¢ BHARAT_OS_SMS_CIRCUIT_OPEN_MS ‚Äî how long the breaker stays open
#   before a half-open probe (default 30000). On probe success the
#   circuit closes; on probe failure it re-opens.
#
# Circuit state is visible at /metrics under bos_sms_circuit_state
# {provider} ‚Äî 0 = closed, 1 = half-open, 2 = open. Alert on >= 2.
# BHARAT_OS_SMS_TIMEOUT_MS=3000
# BHARAT_OS_SMS_CIRCUIT_THRESHOLD=5
# BHARAT_OS_SMS_CIRCUIT_OPEN_MS=30000

# Set to `1` in development to also print OTP bodies to stdout for
# testing. NEVER set in production ‚Äî defeats the ¬ß15 PII discipline.
BHARAT_OS_LOG_OTP_BODIES=0

# Production SMS provider credentials (set the matching block + set
# BHARAT_OS_SMS_PROVIDER above to the provider name).
#
# Phase 5.1 ships real HTTP integrations for gupshup / msg91 /
# twilio ‚Äî when credentials are set, the provider sends real SMS
# via the documented vendor API. Karix is still a stub pending a
# partner contract.

# ‚îÄ‚îÄ Gupshup (India-onshore SMS, DLT-compliant) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Sign up at https://www.gupshup.io/ ‚Üí SMS API. Free tier ~25 SMS/day.
# DLT-registered sender ID + Principal Entity ID + template ID required
# for production India delivery (TRAI regulation).
# BHARAT_OS_SMS_GUPSHUP_USERID=
# BHARAT_OS_SMS_GUPSHUP_PASSWORD=
# BHARAT_OS_SMS_GUPSHUP_SOURCE=
# BHARAT_OS_SMS_GUPSHUP_PRINCIPAL_ENTITY_ID=
# BHARAT_OS_SMS_GUPSHUP_TEMPLATE_ID=

# ‚îÄ‚îÄ MSG91 (high-volume India SMS) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Sign up at https://msg91.com/ ‚Üí API. FLOW_ID is the DLT-registered
# template; without it MSG91 falls back to the generic /api/v5/send
# (development only ‚Äî TRAI requires templates in production).
# BHARAT_OS_SMS_MSG91_AUTH_KEY=
# BHARAT_OS_SMS_MSG91_SENDER_ID=
# BHARAT_OS_SMS_MSG91_FLOW_ID=

# ‚îÄ‚îÄ Twilio (international fallback) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# https://www.twilio.com/console. FROM can be a Twilio number (+1XXX...)
# or a Messaging Service SID (MGxxxx...).
# BHARAT_OS_SMS_TWILIO_ACCOUNT_SID=
# BHARAT_OS_SMS_TWILIO_AUTH_TOKEN=
# BHARAT_OS_SMS_TWILIO_FROM=

# ‚îÄ‚îÄ Karix (stub) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Karix requires a partner contract; their API is not public-self-serve.
# Currently throws SMS_PROVIDER_NOT_CONFIGURED until we implement.
# BHARAT_OS_SMS_KARIX_USERNAME=
# BHARAT_OS_SMS_KARIX_PASSWORD=

# ‚îÄ‚îÄ‚îÄ Phase 5.5 ‚Äî backup snapshots ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

# `scripts/snapshot-store.mjs` writes a point-in-time snapshot to
# <data-root>/backups/bos-store-<timestamp>.<sqlite|dir>. Run on a
# cron / systemd-timer schedule. Retention keeps the newest N.
# BHARAT_OS_DATA_ROOT=.bharat-os
# BHARAT_OS_BACKUP_RETENTION=7

# Operations also expose snapshot metadata via
# GET /api/admin/backup-status (latest snapshot age + count + list).
# Alert on `ageSeconds > 90000` (no successful snapshot in >25h).

# Off-site disaster-recovery: enable the optional `litestream`
# sidecar in docker-compose.yml and set the LITESTREAM_* vars below.
# Litestream streams the SQLite WAL to S3-compatible object storage
# with second-granularity point-in-time restore.
# LITESTREAM_BUCKET=bharat-os-backups
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=
# LITESTREAM_REGION=us-east-1

# ‚îÄ‚îÄ‚îÄ Phase 5.7 ‚Äî ops admin endpoints ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

# Shared-secret token gating the admin API surface (circuit reset,
# recovery-cooldown clear, manual snapshot). MUST be >= 16 chars.
# When unset OR shorter than 16 chars, every admin endpoint refuses
# with 503 "admin_disabled" ‚Äî the safe default.
#
# Generate a strong token with:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
# Send with header: `Authorization: Bearer <token>` + optional
# `X-Bharat-Os-Operator: <your-name>` for audit attribution.
#
# Rotate quarterly + after any suspected leak. Every admin call is
# audited via a typed ledger event so an unauthorised override is
# visible after the fact even if the token leaks briefly.
# BHARAT_OS_ADMIN_TOKEN=

# ‚îÄ‚îÄ‚îÄ Deployment ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

# Public-facing domain. Used by the docker-compose Caddyfile for
# automatic Let's Encrypt issuance.
BHARAT_OS_DOMAIN=bharat-os.example.com

# Internal port the Bharat OS API binds to inside the container.
# Default 8787; rarely changed.
BHARAT_OS_PORT=8787
